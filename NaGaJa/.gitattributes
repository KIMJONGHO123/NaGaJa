# =============================================================
#  .gitattributes — 윈도우(CRLF) ↔ macOS/Linux(LF) 줄바꿈 통일
#  Windows 팀원은 checkout 시 CRLF, commit 시 LF 로 자동 변환됩니다.
# =============================================================

# 기본: 텍스트 파일은 Git이 줄바꿈을 자동으로 정규화
* text=auto eol=lf

# ── 명시적으로 LF 강제 ──
*.dart    text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.xml     text eol=lf
*.gradle  text eol=lf
*.kt      text eol=lf
*.swift   text eol=lf
*.sh      text eol=lf
*.py      text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
Podfile        text eol=lf
Makefile       text eol=lf

# ── Windows 전용 스크립트 ──
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# ── 바이너리 파일 (변환하지 않음) ──
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.svg     binary
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
*.eot     binary
*.pdf     binary
*.zip     binary
*.tar     binary
*.gz      binary
*.apk     binary
*.ipa     binary
*.jar     binary
*.class   binary
*.keystore binary
*.jks     binary
