# =============================================================
#  nagaja — Flutter + Firebase  .gitignore
#  팀원 모두(Win/Mac, VS Code/Android Studio/Cursor/Xcode)가
#  함께 쓸 수 있도록 포괄적으로 작성되었습니다.
# =============================================================


# ──────────────────────────────────────────
# [IDE & Editor]
# ──────────────────────────────────────────

## VS Code
.vscode/

## Android Studio / IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

## Cursor
.cursor/

## Xcode
xcuserdata/
*.xcscmblueprint
*.xccheckout
DerivedData/


# ──────────────────────────────────────────
# [Flutter / Dart]
# ──────────────────────────────────────────

# pub 패키지 캐시 (flutter pub get 으로 복원 가능)
.dart_tool/
.packages
pubspec.lock          # ← 라이브러리 버전 고정이 필요하면 이 줄을 삭제하세요
build/
doc/api/

# Flutter 웹 생성 파일
lib/generated_plugin_registrant.dart

# Coverage
coverage/


# ──────────────────────────────────────────
# [iOS (Xcode / CocoaPods)]
# ──────────────────────────────────────────

ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*
*.xcworkspace/
!default.xcworkspace

# CocoaPods 잠금 파일 (팀 일관성을 위해 보통 커밋 권장이지만, 필요 시 주석 해제)
# ios/Podfile.lock


# ──────────────────────────────────────────
# [Android]
# ──────────────────────────────────────────

android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/**/GeneratedPluginRegistrant.java
android/key.properties       # 서명 키 설정 — 절대 커밋 금지!
*.keystore
*.jks


# ──────────────────────────────────────────
# [Firebase / Cloud Functions]
# ──────────────────────────────────────────

# 서비스 계정 키 — 절대 커밋 금지!
google-services.json
GoogleService-Info.plist
*-service-account*.json
serviceAccountKey.json
.env
.env.*
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log

# Functions 빌드 산출물
functions/lib/
functions/node_modules/


# ──────────────────────────────────────────
# [OS 생성 파일]
# ──────────────────────────────────────────

## macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

## Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

## Linux
*~


# ──────────────────────────────────────────
# [기타]
# ──────────────────────────────────────────

*.log
*.class
*.lock
*.pid
tmp/
temp/
